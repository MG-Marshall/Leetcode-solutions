Given the head of a linked list, rotate the list to the right by k places.

Example
Input: head = [1,2,3,4,5], k = 2
Output: [4,5,1,2,3]
Input: head = [0,1,2], k = 4
Output: [2,0,1]


struct ListNode* rotateRight(struct ListNode* head, int k) {
    if(head == NULL || head->next == NULL) return head;
    struct ListNode *curr = head, *temp, *tail;
    int count = 0;

    while(curr != NULL){
        curr = curr->next;
        count++;
    }
    if(k >= count) k %= count;
    if(k == 0) return head;

    int lastNode = count - k;
    count = 1; curr = head;

    while(lastNode != count){
        curr = curr->next;
        count++;
    }
    tail = curr;
    temp = curr->next;
    
    while(curr->next != NULL){ 
        curr = curr->next;
    }
    tail->next = NULL;
    curr->next = head;
    head = temp;

    return head;
}

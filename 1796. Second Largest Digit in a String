Given an alphanumeric string s, return the second largest numerical digit that appears in s, or -1 if it does not exist.
An alphanumeric string is a string consisting of lowercase English letters and digits.

Example 1:
Input: s = "dfa12321afd"
Output: 2
Example 2:
Input: s = "abc1111"
Output: -1



class Solution {
public:
    int secondHighest(string s) {
        int i, maxx = -1, max2 = -1, n = s.size();
        
        for (i = 0; i < n; i++) {
            if (s[i] >= '0' && s[i] <= '9') {
                int temp = s[i] - '0';
                if (temp > maxx) {
                    max2 = maxx;
                    maxx = temp;
                } 
                else if (temp < maxx && temp > max2)
                    max2 = temp;
            }
        }
        return max2;
    }
};

Given the head of a linked list, return the list after sorting it in ascending order.
Example
Input: head = [4,2,1,3]
Output: [1,2,3,4]
Input: head = [-1,5,3,4,0]
Output: [-1,0,3,4,5]
Input: head = []
Output: []


# 7ms

class Solution {
public:
    ListNode* sortList(ListNode* head) {
        ListNode* temp = head;
        vector<int> list;

        while(temp){
            list.push_back(temp->val);
            temp = temp->next;
        }
        sort(list.begin(), list.end());

        temp = head;
        int i = 0;
        while(temp && i < list.size()){
            temp->val = list[i++];
            temp = temp->next; 
        }
        return head;
    }
};


# 2383 ms

class Solution {
public:
    ListNode* sortList(ListNode* head) {
        if(head == NULL || head->next == NULL) return head;

        ListNode *dummy = new ListNode(INT_MIN);
        dummy->next = head;
        ListNode *curr = dummy, *temp = NULL;

        while(curr->next != NULL){
            int flag = 1;
            if(curr->next->val < curr->val) {
                temp = curr->next;
                curr->next = temp->next;
                
                ListNode *incurr = dummy;
                while(temp->val > incurr->next->val) incurr = incurr->next;
                temp->next = incurr->next;
                incurr->next = temp;
                flag = 0;
            }
            if(flag) curr = curr->next;
        }
        return dummy->next;
    }
};

Given an integer n, add a dot (".") as the thousands separator and return it in string format.
Example 1:
Input: n = 987
Output: "987"
Example 2:
Input: n = 1234
Output: "1.234"



class Solution {
public:
    string thousandSeparator(int n) {
        if(n == 0) return "0";
        string str;
        for(int i = 0; n > 0; i++){
            char ch = (n % 10) + 48;
            str.push_back(ch);
            if((i+1) % 3 == 0) str.push_back('.');
            n /= 10;
        }
        if(str.back() == '.') str.pop_back();
        reverse(str.begin(), str.end());
        return str;
    }
};

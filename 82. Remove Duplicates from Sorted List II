Given the head of a sorted linked list, delete all nodes that have duplicate numbers, leaving only distinct numbers from the 
original list. Return the linked list sorted as well.

Example :
Input: head = [1,2,3,3,4,4,5]
Output: [1,2,5]
Input: head = [1,1,1,2,3]
Output: [2,3]


class Solution {
public:
    ListNode* deleteDuplicates(ListNode* head) {
        if (head == NULL) return NULL;
        ListNode *curr = head, *prev = NULL;

        while (curr != NULL) {
            if (curr->next != NULL && curr->val == curr->next->val) {
                int dup = curr->val;

                while (curr != NULL && curr->val == dup) {
                    curr = curr->next;
                }
                if (prev == NULL) {
                    head = curr;
                } else 
                    prev->next = curr;
            } 
            else {
                prev = curr;
                curr = curr->next;
            }
        }
        return head;
    }
};

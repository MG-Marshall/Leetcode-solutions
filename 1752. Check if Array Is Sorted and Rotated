Given an array nums, return true if the array was originally sorted in non-decreasing order, then rotated some number of positions (including zero). Otherwise,
return false.
There may be duplicates in the original array.
Note: An array A rotated by x positions results in an array B of the same length such that B[i] == A[(i+x) % A.length] for every 
valid index i.
Example 1:
Input: nums = [3,4,5,1,2]
Output: true
Example 2:
Input: nums = [2,1,3,4]
Output: false


class Solution {
public:
    bool check(vector<int>& nums) {
        int i, count = 0, n = nums.size();
        for (i = 1; i < n; i++) {
            if (nums[i - 1] > nums[i])
                count++;
            if (count == 2)
                break;
        }
        if (count == 0)
            return true;
        else if (count == 1 && nums[n - 1] <= nums[0])
            return true;
        return false;
    }
};
